{
  "AutoRefreshMinutes": 10,
  "GroupSimilarityThreshold": 0.78,
  "Collector": {
    "EnableInWebHost": false,
    "AllowWebManualRefresh": false,
    "RunOnStartup": true
  },
  "OpenAI": {
    "DailySummaryModel": "gpt-5.4-nano"
  },
  "Storage": {
    "Provider": "MongoDB"
  },
  "Security": {
    "AdminToken": "",
    "AllowLoopbackAdmin": false
  },
  "ArticleContent": {
    "TimeoutSeconds": 15
  },
  "Mongo": {
    "ConnectionString": "mongodb://127.0.0.1:27017",
    "DatabaseName": "pulsebrief"
  }
}
